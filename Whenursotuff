local function playIntro()
    if globalState.hasSeenIntro then
        IntroOverlay.Visible = false
        return
    end
    
    tween(iTitle, {TextTransparency=0}, 0.6)
    tween(iTitleScale, {Scale=1}, 0.8, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out)
    tween(iSkip, {TextTransparency=0}, 0.6)
    task.wait(0.6)
    
    if IntroOverlay.Visible == false then return end
    
    tween(iSub, {TextTransparency=0}, 0.5)
    tween(iLoadBarBg, {BackgroundTransparency=0}, 0.5)
    tween(iLoadBar, {BackgroundTransparency=0}, 0.5)
    task.wait(0.4)
    
    if IntroOverlay.Visible == false then return end
    
    tween(iLoadBar, {Size=UDim2.new(1,0,1,0)}, 1.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    task.wait(1.4)
    
    if IntroOverlay.Visible == false then return end
    
    local fadeTime = 0.5
    tween(IntroOverlay, {BackgroundTransparency=1}, fadeTime)
    tween(iTitle, {TextTransparency=1}, fadeTime)
    tween(iSub, {TextTransparency=1}, fadeTime)
    tween(iLoadBarBg, {BackgroundTransparency=1}, fadeTime)
    tween(iLoadBar, {BackgroundTransparency=1}, fadeTime)
    tween(iSkip, {TextTransparency=1}, fadeTime)
    
    task.wait(fadeTime)
    IntroOverlay.Visible = false
    globalState.hasSeenIntro = true
    saveGlobalState()
end

