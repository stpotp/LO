    elseif t.name == "Scale" then
        btn.MouseButton1Click:Connect(toggleScaleHelper)
    elseif t.name == "Anchor" or t.name == "Collide" then
        btn.MouseButton1Click:Connect(function()
            local selectionBox = LocalPlayer.PlayerGui.StudioGui.SelectionBox
            if not selectionBox.Adornee then 
                print('Select something first'); return 
            end
            if selectionBox.Adornee == workspace or selectionBox.Adornee == game.ReplicatedStorage then 
                print('Cannot select that'); return 
            end
            
            local count, finalState = 0, false
            local targetAttr = (t.name == "Anchor" and "SL_Anchored") or "SL_CanCollide"
            
            for _, child in pairs(selectionBox.Adornee:GetDescendants()) do
                if child:IsA('BasePart') and child:GetAttribute(targetAttr) ~= nil then
                    child:SetAttribute(targetAttr, not child:GetAttribute(targetAttr))
                    finalState = child:GetAttribute(targetAttr)
                    count = count + 1
                end
            end
            
            local prefix = (t.name == "Anchor") and (finalState and "Anchored " or "Unanchored ") or (finalState and "Collided " or "Uncollided ")
            print(count > 0 and (prefix .. count .. " part(s)") or "No parts found")
        end)
    end
end

