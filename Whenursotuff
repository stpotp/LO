local function loadF3X()
    if hasTool('F3X') then 
        equipTool('F3X') 
    else
        local f3xTool = game:GetObjects('rbxassetid://9797801917')[1]
        f3xTool.CanBeDropped = false
        f3xTool.Name = 'F3X'
        f3xTool.Parent = LocalPlayer.Backpack
        
        -- Custom Script Runtime for F3X Tool
        local function executeF3X(targetTool)
            local moduleCache, moduleReturns, scriptThreads = {}, {}, {}
            
            local function customRequire(targetModule)
                if typeof(targetModule) == 'Instance' then
                    if moduleReturns[targetModule] then 
                        return moduleReturns[targetModule] 
                    elseif moduleCache[targetModule] then 
                        moduleReturns[targetModule] = moduleCache[targetModule]()
                        return moduleReturns[targetModule] 
                    else 
                        return require(targetModule) 
                    end
                end
            end
            
            local function wrapEnvironment(scriptObj, func)
                if not func then return end
                return setfenv(func, setmetatable({script = scriptObj}, {
                    __index = function(_, key)
                        if key == 'require' then 
                            return customRequire
                        elseif key == 'getfenv' then 
                            return function(level)
                                local env = type(level) ~= 'number' and getfenv(level) or getfenv(level == 0 and 2 or level + 1)
                                if env.script == nil then error('Tried to get main environment') end
                                return env
                            end 
                        else 
                            return getfenv()[key] 
                        end
                    end
                }))
            end
            
            local function scanAndWrap(parentObj)
                if parentObj:IsA('Script') or parentObj.ClassName == 'ModuleScript' then
                    local wrappedFunc = wrapEnvironment(parentObj, loadstring(parentObj.Source, '='..parentObj:GetFullName()))
                    if parentObj.ClassName == 'Script' or parentObj.ClassName == 'LocalScript' then 
                        scriptThreads[parentObj] = wrappedFunc
                    elseif parentObj.ClassName == 'ModuleScript' then 
                        moduleCache[parentObj] = wrappedFunc 
                    end
                end
                for _, child in pairs(parentObj:GetChildren()) do scanAndWrap(child) end
            end
            
            scanAndWrap(targetTool)
            for _, threadFunc in pairs(scriptThreads) do task.spawn(threadFunc) end
        end
        
        executeF3X(f3xTool)
        equipTool('F3X')
    end
end

