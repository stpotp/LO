local function tween(obj, props, duration, style, dir)
    duration = duration or 0.35
    style = style or Enum.EasingStyle.Quart
    dir = dir or Enum.EasingDirection.Out
    local tw = TS:Create(obj, TweenInfo.new(duration, style, dir), props)
    tw:Play()
    return tw
end

local function hasTool(toolName)
    return LocalPlayer.Character and (LocalPlayer.Backpack:FindFirstChild(toolName) or LocalPlayer.Character:FindFirstChild(toolName)) and true or false
end

local function equipTool(toolName)
    if hasTool(toolName) and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild('Humanoid') then
        if LocalPlayer.Backpack:FindFirstChild(toolName) then
            LocalPlayer.Character.Humanoid:EquipTool(LocalPlayer.Backpack:FindFirstChild(toolName))
        elseif LocalPlayer.Character:FindFirstChildWhichIsA('Tool') then
            LocalPlayer.Character.Humanoid:UnequipTools()
        end
    end
end

local function HasProperty(instance, property)
    local success, _ = pcall(function() return instance[property] end)
    return success
end

local function MakeScript(scriptType, sourceObj)
    local success, parent = pcall(function() return sourceObj.Parent end)
    local destination = (success and parent) or workspace

    local newScriptObj = game:GetService('ReplicatedStorage').StudioLiteFolder.RigEditScriptFolder.DanceScript.SL_CodeTextBox:Clone()
    newScriptObj.Text = "--// Generated by Allvideo's Model Inserter " .. SCRIPT_VERSION .. "\n\n" .. sourceObj.Source
    
    local wrappedScript = Instance.new(scriptType, destination)
    wrappedScript.Name = sourceObj.Name

    for _, child in pairs(sourceObj:GetChildren()) do 
        child.Parent = wrappedScript 
    end

    newScriptObj.Parent = wrappedScript

    pcall(function() 
        sourceObj.Parent = LocalPlayer
        sourceObj:Destroy() 
    end)
end

local function getHttpFunc()
    if syn and syn.request then return syn.request end
    if http_request then return http_request end
    if request then return request end
    if http and http.request then return http.request end
    if fluxus and fluxus.request then return fluxus.request end
    return nil
end


